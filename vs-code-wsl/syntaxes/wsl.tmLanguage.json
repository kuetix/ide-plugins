{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "WSL",
  "scopeName": "source.wsl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#arrays"
    },
    {
      "include": "#objects"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#templates"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.wsl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.wsl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.wsl",
          "match": "\\b(module|import|extends|const|workflow|state|action|on|end|start|context|as|else)\\b"
        },
        {
          "name": "keyword.control.flow.wsl",
          "match": "\\b(success|error|fail|ok)\\b"
        },
        {
          "name": "constant.language.boolean.wsl",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.wsl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.wsl",
              "match": "\\\\."
            },
            {
              "include": "#templates"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.wsl",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.wsl",
          "match": "->"
        },
        {
          "name": "keyword.operator.wsl",
          "match": ":|,|\\||=|\\."
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.dollar.wsl",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*|\\[\\d+\\])*"
        },
        {
          "name": "entity.name.function.wsl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*/[a-zA-Z_][a-zA-Z0-9_]*(/[a-zA-Z_][a-zA-Z0-9_]*)*"
        },
        {
          "name": "entity.name.type.wsl",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.wsl",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "arrays": {
      "patterns": [
        {
          "name": "meta.structure.array.wsl",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#arrays"
            },
            {
              "include": "#objects"
            },
            {
              "include": "#identifiers"
            },
            {
              "include": "#templates"
            },
            {
              "name": "punctuation.separator.array.wsl",
              "match": ","
            }
          ]
        }
      ]
    },
    "objects": {
      "patterns": [
        {
          "name": "meta.structure.object.wsl",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#arrays"
            },
            {
              "include": "#objects"
            },
            {
              "include": "#identifiers"
            },
            {
              "include": "#templates"
            },
            {
              "name": "punctuation.separator.key-value.wsl",
              "match": ":"
            },
            {
              "name": "punctuation.separator.object.wsl",
              "match": ","
            }
          ]
        }
      ]
    },
    "templates": {
      "patterns": [
        {
          "name": "meta.template.expression.wsl",
          "begin": "<<",
          "end": ">>",
          "patterns": [
            {
              "include": "#identifiers"
            },
            {
              "name": "keyword.operator.pipe.wsl",
              "match": "\\|"
            }
          ]
        }
      ]
    }
  }
}
