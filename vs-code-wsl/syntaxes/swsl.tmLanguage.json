{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SimplifiedWSL",
  "scopeName": "source.swsl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#templates"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.swsl",
          "match": "//.*$"
        },
        {
          "name": "comment.line.hash.swsl",
          "match": "#.*$"
        },
        {
          "name": "comment.block.swsl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.swsl",
          "match": "\\b(module|import|extends|const|def|as)\\b"
        },
        {
          "name": "keyword.control.workflow-type.swsl",
          "match": "\\b(feature|solution|workflow|microservice)\\b"
        },
        {
          "name": "keyword.control.prefix.swsl",
          "match": "\\b(workflow|feature|solution):"
        },
        {
          "name": "constant.language.boolean.swsl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.swsl",
          "match": "\\bnull\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.swsl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.swsl",
              "match": "\\\\."
            },
            {
              "include": "#templates"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.swsl",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.forward-flow.swsl",
          "match": "->"
        },
        {
          "name": "keyword.operator.error-binding.swsl",
          "match": "<-"
        },
        {
          "name": "keyword.operator.terminal.swsl",
          "match": "\\.(?=\\s|$|[^0-9.])"
        },
        {
          "name": "keyword.operator.swsl",
          "match": ":|,|="
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.dollar.swsl",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*"
        },
        {
          "name": "entity.name.function.swsl",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*(/[a-zA-Z_][a-zA-Z0-9_]*)*\\.[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "entity.name.type.swsl",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "templates": {
      "patterns": [
        {
          "name": "meta.embedded.block.swsl",
          "begin": "<<",
          "end": ">>",
          "patterns": [
            {
              "include": "#identifiers"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#strings"
            }
          ]
        }
      ]
    }
  }
}
